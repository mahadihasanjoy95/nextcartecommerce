# ─────────────────────────────────────────────────────────────────────────────
# NextCart Backend — Environment Variables Reference
# ─────────────────────────────────────────────────────────────────────────────
# PURPOSE: This file shows WHICH environment variables the app needs.
#          It contains NO real values — it is safe to commit to git.
#
# HOW TO USE (local development in IntelliJ):
#   1. Open Run/Debug Configurations
#   2. Select your Spring Boot config (NextcartBackendApplication)
#   3. Click "Modify options" → Enable "Environment variables"
#   4. Add each variable below with your real values
#   5. Click OK — your values are stored in IntelliJ only, never in any file
#
# HOW IT WORKS ON EC2:
#   Values live in /opt/nextcart/config/.env.prod (never in git)
#   Loaded via systemd EnvironmentFile directive
# ─────────────────────────────────────────────────────────────────────────────

# Database
DB_URL=jdbc:mysql://localhost:3306/nextcart?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=

# JWT (generate a new one: openssl rand -base64 64)
JWT_SECRET=
JWT_ACCESS_EXPIRY=3600
JWT_REFRESH_EXPIRY=2592000

# Super Admin Seed
SUPERADMIN_EMAIL=superadmin@nextcart.com
SUPERADMIN_PASSWORD=

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_BUCKET=nextcart-media
AWS_S3_BASE_URL=https://nextcart-media.s3.us-east-1.amazonaws.com/

# Email (Gmail App Password — generate at myaccount.google.com/apppasswords)
MAIL_USERNAME=
MAIL_PASSWORD=

# Frontend URLs
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
